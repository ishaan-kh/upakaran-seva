# =====================================================================
# Upakaran Seva — Environment Variables
# Copy this file to .env.local for local dev, set in Vercel for prod
# =====================================================================

# Supabase project URL (e.g., https://abcdefgh.supabase.co)
VITE_SUPABASE_URL=

# Supabase anon (publishable) key — safe to expose to client
VITE_SUPABASE_ANON_KEY=

# Optional: project ref for type generation script
VITE_SUPABASE_PROJECT_REF=
